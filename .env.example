# Required AI provider key for job-description analysis, gap analysis, and resume tailoring.
GOOGLE_API_KEY="MY_GEMINI_API_KEY"
# GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional Gemini model overrides.
GEMINI_TAILOR_MODEL="gemini-2.5-flash"
# GEMINI_JD_MODEL="gemini-2.5-flash"
# GEMINI_GAP_MODEL="gemini-2.5-flash"
# GEMINI_SEARCH_MODEL="gemini-2.5-flash-lite"

# Optional tailoring fallback via OpenRouter + Qwen.
# Used only when Gemini is unavailable at the provider layer during resume tailoring.
# OPENROUTER_API_KEY="sk-or-..."
# OPENROUTER_QWEN_MODEL="qwen/qwen3-32b:nitro"
# OpenRouter Perplexity search is primary for /api/search-jobs when configured.
# Defaults to "perplexity/sonar" if OPENROUTER_API_KEY is present.
# OPENROUTER_PERPLEXITY_SEARCH_MODEL="perplexity/sonar"
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# OPENROUTER_HTTP_REFERER="https://your-vercel-domain.vercel.app"
# OPENROUTER_APP_TITLE="Resume Tailor Pro"
# Optional provider timeouts to keep serverless requests below Vercel limits.
# RTP_GEMINI_TIMEOUT_MS="18000"
# RTP_OPENROUTER_TIMEOUT_MS="18000"

# Public app URL used for API CORS and client links.
APP_URL="https://your-vercel-domain.vercel.app"

# Supabase project configuration.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
# Optional private bucket for persisted default resume DOCX files.
# SUPABASE_RESUME_BUCKET="default-resumes"

# Optional log tuning.
# LOG_LEVEL="info"

# UI theme flag. Set to "true" to revert to the legacy violet/zinc design.
# Leave unset (default) to use the V11 cobalt-blue theme.
# VITE_LEGACY_UI="true"

# Optional quota controls for production.
# Set to "true" to disable quota enforcement entirely.
# DISABLE_USAGE_QUOTAS="false"
# Override free-tier monthly limits for specific operations.
# FREE_TAILOR_LIMIT="5"
# FREE_SEARCH_LIMIT="3"
# Bypass quota enforcement for specific users.
# QUOTA_BYPASS_USER_IDS="user-id-1,user-id-2"
# QUOTA_BYPASS_EMAILS="founder@example.com,ops@example.com"
