{
  "buildCommand": "vite build && npx esbuild api/_index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=api/index.cjs --external:fsevents --external:@playwright/test",
  "outputDirectory": "dist",
  "functions": {
    "api/index.cjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
